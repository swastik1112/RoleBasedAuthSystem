@using RoleBasedAuthSystem.Models.ViewModels
@model IEnumerable<UserViewModel>

@{
    ViewData["Title"] = "Manage Users";
}

<div class="container py-5 animate__animated animate__fadeIn">
    <div class="glass-card p-5">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-5 text-white">
            <h2 class="fw-bold mb-3 mb-md-0">
                <i class="bi bi-people me-3"></i>Manage Users
            </h2>
            <div>
                <span class="badge bg-primary fs-5 px-4 py-2">
                    @Model.Count() users found
                </span>
            </div>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5 opacity-75">
                <i class="bi bi-inbox-fill display-1 mb-4 d-block"></i>
                <h5>No regular users found</h5>
                <p>When users register, they will appear here</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover text-white align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td class="fw-medium">@user.Email</td>
                                <td>
                                    <span class="badge bg-success fs-6 px-3 py-2">
                                        @user.Role
                                    </span>
                                </td>
                                <td>
                                    <a asp-action="EditUser" asp-route-id="@user.Id"
                                       class="btn btn-sm btn-outline-info me-2 btn-ripple">
                                        <i class="bi bi-pencil-square"></i> Edit
                                    </a>

                                    <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post"
                                          class="d-inline"
                                          onsubmit="return confirm('Are you sure you want to delete @user.Email?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger btn-ripple">
                                            <i class="bi bi-trash3"></i> Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <div class="text-center mt-5 pt-4 border-top border-light border-opacity-25">
            <a asp-controller="Admin" asp-action="Dashboard"
               class="btn btn-outline-light btn-lg px-5 btn-ripple">
                ← Back to Admin Dashboard
            </a>
        </div>
    </div>
</div>