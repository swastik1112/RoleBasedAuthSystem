@using RoleBasedAuthSystem.Models.ViewModels
@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<!-- Same outer container + gradient background as Login -->

<div class="min-vh-100 d-flex align-items-center" style="background: linear-gradient(-45deg, #667eea, #764ba2, #6B8DD6, #8E37D7); background-size: 400% 400%; animation: gradientBG 15s ease infinite;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="card border-0 shadow-lg overflow-hidden animate__animated animate__fadeInUp" style="border-radius: 1.5rem; backdrop-filter: blur(12px); background: rgba(255,255,255,0.15);">
                    <div class="row g-0">

                        <!-- Left Side - Welcome (slightly different text) -->
                        <div class="col-lg-6 d-none d-lg-block bg-gradient-primary text-white p-5 position-relative overflow-hidden">
                            <div class="position-absolute top-0 start-0 w-100 h-100 opacity-25" style="background: radial-gradient(circle at 30% 20%, rgba(255,255,255,0.4) 0%, transparent 60%);"></div>
                            <div class="d-flex flex-column h-100 justify-content-center position-relative z-1">
                                <h2 class="display-5 fw-bold mb-4 animate__animated animate__fadeInDown">Join Us Today!</h2>
                                <p class="lead opacity-75 mb-5 animate__animated animate__fadeIn animate__delay-1s">
                                    Create your account and start exploring amazing features.
                                </p>
                                <div class="mt-auto">
                                    <small>Already have an account?</small><br>
                                    <a href="@Url.Action("Login")" class="text-white fw-bold text-decoration-none">Sign in →</a>
                                </div>
                            </div>
                        </div>

                        <!-- Right Side - Register Form -->
                        <div class="col-lg-6 p-5 p-lg-5">
                            <div class="text-center mb-5">
                                <h3 class="fw-bold mb-1">Create Account</h3>
                                <p class="text-muted">Fill in your details to get started</p>
                            </div>

                            <form asp-action="Register" method="post">
                                <div asp-validation-summary="ModelOnly" class="text-danger text-center mb-4"></div>

                                <div class="form-floating mb-4">
                                    <input asp-for="Email" class="form-control" id="floatingEmailReg" placeholder="name@example.com" autocomplete="email" required />
                                    <label for="floatingEmailReg">Email address</label>
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>

                                <div class="form-floating mb-4 position-relative">
                                    <input asp-for="Password" class="form-control pe-5" id="floatingPasswordReg" placeholder="Password" type="password" autocomplete="new-password" required />
                                    <label for="floatingPasswordReg">Password</label>
                                    <button type="button" class="btn btn-link position-absolute top-50 end-0 translate-middle-y pe-3" onclick="togglePassword('floatingPasswordReg', this)">
                                        <i class="bi bi-eye-slash"></i>
                                    </button>
                                    <span asp-validation-for="Password" class="text-danger"></span>
                                </div>

                                <div class="form-floating mb-4">
                                    <input asp-for="ConfirmPassword" class="form-control" id="floatingConfirmPassword" placeholder="Confirm password" type="password" autocomplete="new-password" required />
                                    <label for="floatingConfirmPassword">Confirm Password</label>
                                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                                </div>

                                <button type="submit" class="btn btn-primary w-100 btn-lg fw-bold position-relative overflow-hidden mt-3">
                                    <span class="btn-text">Sign Up</span>
                                    <span class="ripple"></span>
                                </button>
                            </form>

                            <div class="text-center mt-4">
                                <small class="text-muted">Already have an account? <a href="@Url.Action("Login")" class="fw-bold text-primary text-decoration-none">Login here</a></small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script>
        function togglePassword(inputId, button) {
            const input = document.getElementById(inputId);
            const icon = button.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            } else {
                input.type = 'password';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            }
        }
    </script>
    <style>
        @@keyframes gradientBG {
            0%

        {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }

        100% {
            background-position: 0% 50%;
        }

        }

        .animate__fadeInUp {
            animation-duration: 0.9s;
        }

        .btn-primary {
            transition: all 0.3s;
        }

            .btn-primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 20px rgba(108,99,255,0.4);
            }

        .ripple {
            position: absolute;
            background: rgba(255,255,255,0.3);
            border-radius: 50%;
            transform: scale(0);
            animation: rippleAnim 0.6s linear;
            pointer-events: none;
        }
        @@keyframes rippleAnim {
            to

        {
            transform: scale(4);
            opacity: 0;
        }

        }
    </style>
}

<!-- Same Scripts section as Login (toggle password + animations) -->