@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container py-5 animate__animated animate__fadeIn">
    <div class="glass-card p-5 text-center text-white">
        <h1 class="display-5 fw-bold mb-4">Admin Dashboard</h1>
        <p class="lead mb-5 opacity-75">
            Welcome, Administrator • You can manage regular users
        </p>

        <div class="row g-4 justify-content-center mt-5">
            <div class="col-md-6 col-lg-4">
                <div class="card-hover glass-card p-5 h-100 d-flex flex-column justify-content-center align-items-center">
                    <i class="bi bi-people-fill display-3 text-info mb-4"></i>
                    <h4 class="fw-bold mb-3">Manage Users</h4>
                    <p class="text-center opacity-75 mb-4">
                        View, edit and remove regular user accounts
                    </p>
                    <a asp-action="ManageUsers" class="btn btn-outline-light btn-lg px-5 btn-ripple">
                        Open User Management →
                    </a>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="card-hover glass-card p-5 h-100 d-flex flex-column justify-content-center align-items-center position-relative">
                    <div class="position-absolute top-0 end-0 mt-3 me-3">
                        <span class="badge bg-warning text-dark">Soon</span>
                    </div>
                    <i class="bi bi-bar-chart-line-fill display-3 text-warning mb-4"></i>
                    <h4 class="fw-bold mb-3">User Statistics</h4>
                    <p class="text-center opacity-75 mb-4">
                        Overview of user activity and registrations
                    </p>
                    <button class="btn btn-outline-light btn-lg px-5 btn-ripple" disabled>
                        View Stats
                    </button>
                </div>
            </div>
        </div>

        <div class="mt-5 pt-4 border-top border-light border-opacity-25">
            <small class="opacity-75">
                Note: You cannot modify SuperAdmin or other Admin accounts
            </small>
        </div>
    </div>
</div>