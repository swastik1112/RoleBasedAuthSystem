@using RoleBasedAuthSystem.Models.ViewModels
@model UserListViewModel
@{
    ViewData["Title"] = "Manage Users";
}

<div class="container py-5 animate__animated animate__fadeIn">
    <div class="glass-card p-5">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-4 text-white">
            <h2 class="fw-bold mb-3 mb-md-0">
                <i class="bi bi-people me-3"></i>Manage Users
            </h2>
            <span class="badge bg-primary fs-5 px-4 py-2">
                @Model.TotalUsers users
            </span>
        </div>

        <!-- Search Form -->
        <form asp-action="ManageUsers" method="get" class="mb-4">
            <div class="input-group input-group-lg">
                <input type="text" name="searchTerm" value="@Model.SearchTerm"
                       class="form-control bg-transparent text-white border-light"
                       placeholder="Search by email..." />
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-search"></i> Search
                </button>
                @if (!string.IsNullOrEmpty(Model.SearchTerm))
                {
                    <a asp-action="ManageUsers" class="btn btn-outline-light ms-2">
                        Clear
                    </a>
                }
            </div>
        </form>

        @if (!Model.Users.Any())
        {
            <div class="text-center py-5 opacity-75">
                <i class="bi bi-inbox-fill display-1 mb-4 d-block"></i>
                <h5>No users found</h5>
                @if (!string.IsNullOrEmpty(Model.SearchTerm))
                {
                    <p>Try a different search term or <a asp-action="ManageUsers" class="text-light">clear search</a></p>
                }
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover text-white align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td class="fw-medium">@user.Email</td>
                                <td>
                                    <span class="badge @(user.Role == "SuperAdmin" ? "bg-danger" : user.Role == "Admin" ? "bg-warning" : "bg-success")">
                                        @user.Role
                                    </span>
                                </td>
                                <td>
                                    @if (user.IsLocked)
                                    {
                                        <span class="badge bg-danger">
                                            <i class="bi bi-lock-fill"></i> Locked
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-unlock-fill"></i> Active
                                        </span>
                                    }
                                </td>
                                <td>                            

                                    @if (user.IsLocked)
                                    {
                                        <form asp-action="UnlockUser" asp-route-id="@user.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-success"
                                                    onclick="return confirm('Unlock @user.Email?');">
                                                Unlock
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="LockUser" asp-route-id="@user.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    onclick="return confirm('Lock @user.Email?');">
                                                Lock
                                            </button>
                                        </form>
                                    }
                                    <!-- Delete form remains here -->
                                    <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-sm btn-outline-info me-2">Edit</a>
                                    <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" class="d-inline" onsubmit="return confirm('Delete user @user.Email?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger btn-ripple">Delete</button>
                                    </form>                                
                                </td>                               
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <nav aria-label="User pagination" class="mt-4">
                    <ul class="pagination pagination-lg justify-content-center">
                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="ManageUsers" 
                               asp-route-searchTerm="@Model.SearchTerm" 
                               asp-route-page="@(Model.CurrentPage - 1)">
                                Previous
                            </a>
                        </li>

                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-action="ManageUsers" 
                                   asp-route-searchTerm="@Model.SearchTerm" 
                                   asp-route-page="@i">
                                    @i
                                </a>
                            </li>
                        }

                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="ManageUsers" 
                               asp-route-searchTerm="@Model.SearchTerm" 
                               asp-route-page="@(Model.CurrentPage + 1)">
                                Next
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        }

        <div class="text-center mt-5">
            <a asp-controller="SuperAdmin" asp-action="Dashboard" class="btn btn-outline-light btn-lg px-5">
                ← Back to Dashboard
            </a>
        </div>
    </div>
</div>